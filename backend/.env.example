# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-a-different-random-secret

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/medassist
REDIS_URL=redis://localhost:6379/0
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=medassist
INFLUXDB_BUCKET=vitals

# EURI API Gateway (OpenAI-compatible) — https://euron.one/euri
# Get your key at: https://euron.one/euri
EURI_API_KEY=                        # your-euri-api-key-here
EURI_BASE_URL=https://api.euron.one/api/v1/euri
# Comma-separated model names that must call EURI (default: gpt-4o-mini) even if OPENAI_BASE_URL is api.openai.com
MODELS_ROUTE_VIA_EURI=gpt-4o-mini
OPENAI_API_KEY=                      # OpenAI key for non-routed models; EURI_API_KEY used for routed models
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Voice-specific OpenAI credentials — real OpenAI for TTS/STT/Realtime
# EURI does not support voice models; use a real OpenAI key here
OPENAI_VOICE_API_KEY=                # your-real-openai-api-key-for-voice
OPENAI_VOICE_BASE_URL=https://api.openai.com/v1
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# OpenAI Realtime (browser voice) — gpt-realtime + listening profiles (noise reduction + server VAD)
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
# Default session profile when client omits listening_profile: quiet | noisy | speaker
OPENAI_LISTENING_PROFILE=quiet

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=medical-knowledge

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# S3 / MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=medassist-reports
S3_ENDPOINT_URL=                    # For MinIO in dev

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email) — leave empty to send via SMTP (e.g. Gmail) below
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Gmail / Google SMTP (appointment + transactional mail via EmailClient)
# Use port 587 + STARTTLS (default). For port 465 use SMTP_USE_SSL=true and SMTP_USE_TLS=false.
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords.
# Never commit real passwords; copy this block to .env and fill SMTP_PASSWORD locally.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=medassisteuronhealthcare@gmail.com
SMTP_PASSWORD=your-google-app-password-here
SMTP_FROM_EMAIL=medassisteuronhealthcare@gmail.com
SMTP_FROM_NAME=MedAssist AI
# Legacy alias (optional if SMTP_USER is set)
# SMTP_USERNAME=medassisteuronhealthcare@gmail.com

# Daily.co (Video)
DAILY_API_KEY=
DAILY_DOMAIN=

# Celery (Docker Compose overrides broker to redis://redis:6379/…)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Run tasks in the API process (no celery-worker). Useful for local email debugging only.
# CELERY_TASK_ALWAYS_EAGER=false
# CELERY_TASK_EAGER_PROPAGATES=true

# Encryption
PHI_ENCRYPTION_KEY=                 # AES-256 key for PHI encryption
