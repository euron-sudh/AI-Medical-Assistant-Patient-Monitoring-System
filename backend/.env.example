# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-a-different-random-secret

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/medassist
REDIS_URL=redis://localhost:6379/0
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=medassist
INFLUXDB_BUCKET=vitals

# EURI API Gateway (OpenAI-compatible) — https://euron.one/euri
# Get your key at: https://euron.one/euri
EURI_API_KEY=                        # your-euri-api-key-here
EURI_BASE_URL=https://api.euron.one/api/v1/euri
# Comma-separated model names that must call EURI (default: gpt-4o-mini) even if OPENAI_BASE_URL is api.openai.com
MODELS_ROUTE_VIA_EURI=gpt-4o-mini
OPENAI_API_KEY=                      # OpenAI key for non-routed models; EURI_API_KEY used for routed models
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# OpenAI Realtime (browser voice) — gpt-realtime + listening profiles (noise reduction + server VAD)
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
# Default session profile when client omits listening_profile: quiet | noisy | speaker
OPENAI_LISTENING_PROFILE=quiet

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=medical-knowledge

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# S3 / MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=medassist-reports
S3_ENDPOINT_URL=                    # For MinIO in dev

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Daily.co (Video)
DAILY_API_KEY=
DAILY_DOMAIN=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Encryption
PHI_ENCRYPTION_KEY=                 # AES-256 key for PHI encryption
