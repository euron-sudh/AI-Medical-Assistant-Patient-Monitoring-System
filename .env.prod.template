# =============================================================================
# MedAssist AI — Production Environment Variables
# Copy to .env.prod and fill in values from 'make gcp-setup' output
# =============================================================================

# Flask
FLASK_APP=wsgi.py
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Database — Cloud SQL PostgreSQL
# Get CLOUD_SQL_IP from .gcp-outputs after running gcp-setup
DATABASE_URL=postgresql://medassist:DB_PASSWORD_HERE@CLOUD_SQL_IP:5432/medassist

# Redis — local container in docker-compose
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# EURI API Gateway (OpenAI-compatible)
EURI_API_KEY=YOUR_EURI_API_KEY
EURI_BASE_URL=https://api.euron.one/api/v1/euri
OPENAI_API_KEY=YOUR_EURI_API_KEY
OPENAI_BASE_URL=https://api.euron.one/api/v1/euri
OPENAI_ORG_ID=
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Pinecone (optional — leave empty to skip vector search)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=medical-knowledge

# InfluxDB (deferred — leave empty)
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=medassist
INFLUXDB_BUCKET=vitals

# Elasticsearch (deferred — leave empty)
ELASTICSEARCH_URL=

# Cloud Storage (S3-compatible via HMAC keys)
# Get HMAC keys from .gcp-outputs or GCP Console > Cloud Storage > Settings > Interoperability
AWS_ACCESS_KEY_ID=HMAC_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=HMAC_SECRET_KEY_HERE
AWS_REGION=us-central1
S3_BUCKET_NAME=medassist-ai-prod-medassist-reports
S3_ENDPOINT_URL=https://storage.googleapis.com

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid Email (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Daily.co Video (optional)
DAILY_API_KEY=
DAILY_DOMAIN=

# Encryption
PHI_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Rate Limiting
RATELIMIT_STORAGE_URI=redis://redis:6379/0
