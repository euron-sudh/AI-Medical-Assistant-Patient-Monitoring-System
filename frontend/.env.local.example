# ===========================================
# MedAssist AI - Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Telemedicine (Daily.co)
NEXT_PUBLIC_DAILY_API_KEY=your-daily-api-key-here

# OpenAI Realtime (optional overrides; backend session also reads server env)
NEXT_PUBLIC_OPENAI_REALTIME_MODEL=gpt-realtime
NEXT_PUBLIC_OPENAI_REALTIME_VOICE=marin
# Default listening mode before user changes UI: quiet | noisy | speaker
NEXT_PUBLIC_LISTENING_PROFILE=quiet

# Feature Flags
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_TELEMEDICINE=true
NEXT_PUBLIC_ENABLE_REAL_TIME_MONITORING=true

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
